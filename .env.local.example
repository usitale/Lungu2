# ============================================================
# LUNGU SAFARI TOURS — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
# ============================================================

# ── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.lungusafaritours.com

# ── PayPal ──────────────────────────────────────────────────
# Get from https://developer.paypal.com/dashboard/applications
# Use sandbox credentials for testing, live credentials for production
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox   # Change to "live" for production

# ── PayFast ─────────────────────────────────────────────────
# Get from https://www.payfast.co.za/merchant
PAYFAST_MERCHANT_ID=your_payfast_merchant_id
PAYFAST_MERCHANT_KEY=your_payfast_merchant_key
PAYFAST_PASSPHRASE=your_optional_payfast_passphrase
PAYFAST_MODE=sandbox   # Change to "live" for production

# PayFast Sandbox endpoint: https://sandbox.payfast.co.za/eng/process
# PayFast Live endpoint:    https://www.payfast.co.za/eng/process

# ── Payment Redirect URLs ───────────────────────────────────
PAYFAST_RETURN_URL=https://www.lungusafaritours.com/payment/success
PAYFAST_CANCEL_URL=https://www.lungusafaritours.com/payment/cancel
PAYFAST_NOTIFY_URL=https://www.lungusafaritours.com/api/payment/payfast/notify

# ── WhatsApp Chat ───────────────────────────────────────────
# Include country code, no + or spaces e.g. 260971234567
NEXT_PUBLIC_WHATSAPP_NUMBER=260971234567

# ── Facebook Messenger ──────────────────────────────────────
# Your Facebook Page ID (not username)
NEXT_PUBLIC_MESSENGER_PAGE_ID=your_facebook_page_id

# ── Tawk.to Live Chat ───────────────────────────────────────
# Get from https://www.tawk.to — Dashboard > Admin > Chat Widget
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=your_tawkto_property_id
NEXT_PUBLIC_TAWKTO_WIDGET_ID=default

# ── Email (for booking notifications) ──────────────────────
# Configure with SendGrid, Resend, or any SMTP provider
BOOKING_EMAIL_RECIPIENT=bookings@lungusafaritours.com
EMAIL_API_KEY=your_email_api_key
